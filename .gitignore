# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.ipynb_checkpoints/

# Environments
.env
.env.*
.venv/
venv/

# Secrets and local credentials
*.pem
*.key
*.pgpass
credentials*
secrets*

# Raw/vendor data must never be committed
data/raw/*
data/interim/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Local schema/artifact outputs are regenerated by users with their own entitlements
artifacts/schema/*
artifacts/processed/*
artifacts/model_runs/*
artifacts/tables/*
artifacts/figures_static/*
artifacts/figures_interactive/*
artifacts/logs/*
!artifacts/schema/.gitkeep
!artifacts/processed/.gitkeep
!artifacts/model_runs/.gitkeep
!artifacts/tables/.gitkeep
!artifacts/figures_static/.gitkeep
!artifacts/figures_interactive/.gitkeep
!artifacts/logs/.gitkeep

# Workspace logs
logs/

# Private run wrappers and machine-specific schema contracts
scripts/cluster_runs/
configs/schema_contract.yaml
docs/schema_contract.md

# Local run reports with machine-specific paths
docs/003_pilot_extract_audit.md
docs/004_pilot_panel_network_audit.md
docs/005_full_panel_network_audit.md
docs/006_baseline_signal_results.md
docs/007_formal_econometrics_results.md
docs/008_oos_ml_results.md
docs/009_portfolio_costs_and_factor_attribution.md
docs/010_robustness_suite.md

# Long-form monthly/name-level public copies; keep summary tables only
docs/assets/tables/*monthly*.csv
docs/assets/tables/*holding_counts*.csv
docs/assets/tables/*turnover*.csv
docs/assets/tables/*monthly_coefficients*.csv

# Local editor
.vscode/
.idea/

# OS
.DS_Store
